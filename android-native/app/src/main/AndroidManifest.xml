<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".AriaApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Aria">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Aria">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".widget.AriaWidgetReceiver"
            android:exported="false"
            android:label="@string/widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/aria_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.StreakWidgetReceiver"
            android:exported="false"
            android:label="@string/streak_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/aria_streak_widget_info" />
        </receiver>

        <activity
            android:name=".widget.StreakConfigActivity"
            android:exported="false"
            android:theme="@style/Theme.Aria">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".widget.TaskCalWidgetReceiver"
            android:exported="false"
            android:label="@string/taskcal_widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/aria_taskcal_widget_info" />
        </receiver>

        <activity
            android:name=".widget.TaskCalConfigActivity"
            android:exported="false"
            android:theme="@style/Theme.Aria">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".notif.ReminderReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.aria.app.REMINDER_FIRE" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
